# ==========================================
# FAMS — AssuraBackend Environment Variables
# ==========================================
# Copy this file to .env and fill in your local values.
# The .env file is gitignored and must NEVER be committed.
# ==========================================

# ------------------------------------------
# Application
# ------------------------------------------
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000;https://localhost:5001

# ------------------------------------------
# Database (SQL Server)
# ------------------------------------------
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=AssuraFAMS
DB_USER=sa
DB_PASSWORD=your_strong_password_here
# Full connection string (takes precedence if set)
# DATABASE_URL=Server=localhost,1433;Database=AssuraFAMS;User Id=sa;Password=your_strong_password_here;TrustServerCertificate=True;

# ------------------------------------------
# JWT Authentication
# ------------------------------------------
JWT_SECRET_KEY=your_super_secret_key_at_least_32_characters_long
JWT_ISSUER=AssuraBackend
JWT_AUDIENCE=AssuraApp
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# ------------------------------------------
# Email / SMTP (for Notifications)
# ------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_NAME=FAMS Assura

# ------------------------------------------
# CORS (comma-separated allowed origins)
# ------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:4200,https://yourdomain.com

# ------------------------------------------
# Logging
# ------------------------------------------
LOG_LEVEL=Information
